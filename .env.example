# Local runtime config. Copy to `.env.local` and fill only what you need.

# Feishu group bot webhook. Not required for `npm run start:dry`.
# FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxx

# Optional custom file paths. Relative paths are resolved from project root.
# PORTFOLIO_PATH=./data/portfolio.json
# STRATEGY_PATH=./data/strategy.json
# STATE_PATH=./state.json

# Optional debug switches.
# DRY_RUN=1
# FORCE_TRIGGER=1
